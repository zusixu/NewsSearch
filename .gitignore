# ---------------------------------------------------------------------------
# Secrets — NEVER commit
# ---------------------------------------------------------------------------
.env
.env.*
!.env.example

# ---------------------------------------------------------------------------
# Python
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
dist/
build/
*.egg

# ---------------------------------------------------------------------------
# Data & runtime — generated by pipeline, not source code
# ---------------------------------------------------------------------------
data/db/*.db
data/db/*.db-journal
data/db/*.db-wal
data/raw/
data/logs/
data/reports/

# Keep .gitkeep for directory structure
!data/**/.gitkeep

# ---------------------------------------------------------------------------
# IDE & editor
# ---------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~

# ---------------------------------------------------------------------------
# Claude Code local settings
# ---------------------------------------------------------------------------
.claude/settings.local.json
